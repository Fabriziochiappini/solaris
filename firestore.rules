rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Submission dal modulo di contatto del sito pubblico:
    // chiunque può creare (validato), nessuno può leggere/modificare/cancellare dal client
    // (solo dal pannello admin con auth)
    match /contact_submissions/{id} {
      allow create: if request.resource.data.nome is string
                    && request.resource.data.cognome is string
                    && request.resource.data.email is string
                    && request.resource.data.messaggio is string
                    && request.resource.data.messaggio.size() > 0
                    && request.resource.data.messaggio.size() < 5000;
      allow read, update, delete: if request.auth != null;
    }

    // Catalogo veicoli e accessori: lettura pubblica, scrittura solo admin autenticati
    match /veicoli/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /accessori/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics: incrementi pubblici (visite/click), letture solo admin
    match /analytics/{id} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Default: tutto chiuso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
